<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.untionglim.daily-work-report-reminder</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/untionglim/.local/bin/daily-work-report-reminder</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>17</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/untionglim/Library/Logs/daily-work-report-reminder.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/untionglim/Library/Logs/daily-work-report-reminder.err</string>
</dict>
</plist>
