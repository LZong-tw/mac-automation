#!/bin/bash
# memory-guardian — keep memory pressure from getting high enough to kill
# WindowServer (which tears down and rebuilds the entire GUI session).
# Run by the com.untionglim.memory-guardian LaunchAgent every 2 minutes.
#
# WARN  level: notification (30-min cooldown)
# CRIT  level: notification + automatic actions (when AUTO_ACT=1):
#              quit sacrificial apps, stop an idle podman VM
#
# launchd ships a minimal PATH; podman et al. must be added here.
export PATH="/opt/podman/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

WARN_FREE_PCT=25      # warn when free % drops below this
CRIT_FREE_PCT=15      # critical when free % drops below this
WARN_SWAP_PCT=75      # warn when swap usage % exceeds this
CRIT_SWAP_PCT=90      # critical when swap usage % exceeds this
AUTO_ACT=1            # 1 = at CRIT, auto-quit SACRIFICE_APPS and stop podman VM
SACRIFICE_APPS=()     # apps that may be auto-quit at CRIT; empty = notify only (idle podman VM is still stopped)
DEEP_IDLE_HOURS=2     # container-level deep idle: postgres counts as idle only after this many hours without client activity
CPU_IDLE_PCT=1.0      # non-postgres containers: idle only below this CPU %
COOLDOWN_MIN=30

LOG="$HOME/.local/log/memory-guardian.log"
STATE="$HOME/.local/log/.memory-guardian-laststamp"

free_pct=$(memory_pressure -Q | awk -F': ' '/free percentage/ {gsub(/%/,"",$2); print int($2)}')
read -r swap_total swap_used <<<"$(sysctl -n vm.swapusage | awk '{gsub(/M$/,"",$3); gsub(/M$/,"",$6); print $3, $6}')"
swap_pct=0
[ -n "$swap_total" ] && [ "${swap_total%.*}" -gt 0 ] && swap_pct=$(awk "BEGIN{printf \"%d\", $swap_used*100/$swap_total}")

ts() { date "+%F %T"; }
log() { echo "$(ts) $*" >> "$LOG"; }
notify() { osascript -e "display notification \"$2\" with title \"$1\" sound name \"Sosumi\"" 2>/dev/null; }

level=OK
{ [ "$free_pct" -lt "$CRIT_FREE_PCT" ] || [ "$swap_pct" -gt "$CRIT_SWAP_PCT" ]; } && level=CRIT
[ "$level" = OK ] && { [ "$free_pct" -lt "$WARN_FREE_PCT" ] || [ "$swap_pct" -gt "$WARN_SWAP_PCT" ]; } && level=WARN

[ "$level" = OK ] && exit 0

# Notification cooldown (CRIT is exempt)
now=$(date +%s); last=$(cat "$STATE" 2>/dev/null || echo 0)
if [ "$level" = WARN ] && [ $((now - last)) -lt $((COOLDOWN_MIN * 60)) ]; then
    exit 0
fi
echo "$now" > "$STATE"

top3=$(/bin/ps -axo rss=,comm= | awk '{n=split($2,p,"/"); rss[p[n]]+=$1} END {for(c in rss) printf "%.1fG %s\n", rss[c]/1048576, c}' | sort -rn | head -3 | tr '\n' ' ')
log "$level free=${free_pct}% swap=${swap_pct}% top: $top3"

if [ "$level" = WARN ]; then
    notify "記憶體壓力警告" "free ${free_pct}% / swap ${swap_pct}%。建議關閒置 app。Top: $top3"
    exit 0
fi

# CRIT
notify "記憶體危急!" "free ${free_pct}% / swap ${swap_pct}%,再不處理 session 可能整個重建"
if [ "$AUTO_ACT" = 1 ]; then
    acted=""
    for app in "${SACRIFICE_APPS[@]}"; do
        if pgrep -qf "$app.app"; then
            osascript -e "tell application \"$app\" to quit" 2>/dev/null
            log "CRIT action: quit $app"
            acted="$acted $app"
        fi
    done
    if ! command -v podman >/dev/null; then
        log "CRIT skip: podman not in PATH"
    elif ! podman machine list --format '{{.Running}}' 2>/dev/null | grep -q true; then
        log "CRIT skip: podman VM not running"
    else
        # Idle requires ALL of:
        #  1) no podman CLI process on the host (during build/pull, `ps`
        #     shows no containers, so `podman ps` alone is not enough).
        #     Compare real binary names — `pgrep -f` would false-positive on
        #     any unrelated process whose argv happens to contain the string.
        #  2) `podman ps -q` succeeds AND is empty — a failed query (broken
        #     VM) always counts as not-idle; never kill on bad data.
        if /bin/ps -axo comm= | grep -qE '(^|/)podman$'; then
            log "CRIT skip: podman CLI process running on host"
        else
            ps_out=$(podman ps -q 2>/dev/null); ps_rc=$?
            if [ "$ps_rc" -ne 0 ]; then
                log "CRIT skip: podman ps failed (rc=$ps_rc), not assuming idle"
            else
                # Deep-idle check: the VM stops only if EVERY running
                # container is idle. Any probe failure → not idle
                # (prefer missing a stop over killing something in use).
                deep_idle=1
                for cid in $ps_out; do
                    cname=$(podman inspect --format '{{.Name}}' "$cid" 2>/dev/null)
                    pguser=$(podman inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$cid" 2>/dev/null | awk -F= '/^POSTGRES_USER=/{print $2}')
                    if [ -n "$pguser" ]; then
                        # postgres: seconds since last client activity,
                        # excluding this probe itself (no sessions = forever).
                        idle_sec=$(podman exec "$cid" psql -U "$pguser" -At -c \
                            "select coalesce(extract(epoch from now() - max(state_change))::bigint, 999999999) \
                             from pg_stat_activity \
                             where backend_type='client backend' and pid <> pg_backend_pid();" 2>/dev/null)
                        if ! [[ "$idle_sec" =~ ^[0-9]+$ ]] || [ "$idle_sec" -lt $((DEEP_IDLE_HOURS * 3600)) ]; then
                            deep_idle=0
                            log "CRIT skip: $cname last pg activity ${idle_sec:-query-failed}s ago (< ${DEEP_IDLE_HOURS}h)"
                            break
                        fi
                    else
                        # other containers: single CPU sample below threshold
                        cpu=$(podman stats --no-stream --format '{{.CPUPerc}}' "$cid" 2>/dev/null | tr -d '%')
                        if [ -z "$cpu" ] || awk "BEGIN{exit !($cpu >= $CPU_IDLE_PCT)}"; then
                            deep_idle=0
                            log "CRIT skip: $cname CPU ${cpu:-unknown}% (>= ${CPU_IDLE_PCT}%)"
                            break
                        fi
                    fi
                done
                if [ "$deep_idle" = 1 ]; then
                    if podman machine stop 2>>"$LOG"; then
                        log "CRIT action: podman machine stop (all containers deep-idle)"
                        acted="$acted podman-VM"
                    else
                        log "CRIT: podman machine stop FAILED (rc=$?)"
                    fi
                fi
            fi
        fi
    fi
    [ -n "$acted" ] && notify "已自動處理" "關閉:$acted"
fi
exit 0
